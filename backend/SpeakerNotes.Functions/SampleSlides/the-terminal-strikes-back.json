{
  "title": "Main Features",
  "slides": [
    {
      "headlines": "Two Operating Modes",
      "sections": [
        {
          "header": "Programmatic Mode",
          "bullets": [
            "copilot -p \"list my open PRs\"",
            "Perfect for scripting and automation"
          ]
        },
        {
          "header": "Interactive Mode",
          "bullets": [
            "Full command access in terminal",
            "Commands start with /"
          ]
        }
      ]
    },
    {
      "headlines": "Essential Commands",
      "bullets": [
        "/update - CLI updates (certain installers)",
        "/models - Switch between available models",
        "/ide - View diffs and code changes",
        "/context - Manage workspace context",
        "/env - Configure environment variables"
      ]
    },
    {
      "headlines": "Advanced Features",
      "sections": [
        {
          "header": "Modes",
          "bullets": [
            "Normal mode - Standard operation",
            "Plan mode - Structured planning ([[PLAN]])",
            "Autopilot - Autonomous agents"
          ]
        }
      ]
    },
    {
      "headlines": "Session Management",
      "bullets": [
        "/session - View session history",
        "copilot --resume - Continue previous session",
        "copilot --continue - Resume with context",
        "/share - Share session with others"
      ]
    },
    {
      "headlines": "Workspace Control",
      "bullets": [
        "/add-dir - Add directory to context",
        "/ide - Visual diff exploration",
        "/fleet - Launch multiple agents in parallel"
      ]
    },
    {
      "headlines": "Agent Capabilities",
      "bullets": [
        "Rubberduck - Code review with GPT-5.4",
        "Task agents - Parallel execution",
        "Explore agents - Codebase investigation",
        "Custom agents - Project-specific workflows"
      ]
    },
    {
      "headlines": "Extensibility & Configuration",
      "sections": [
        {
          "header": "Plugins",
          "bullets": [
            "/plugin marketplace list",
            "/plugin marketplace add",
            "/plugin install"
          ]
        },
        {
          "header": "LSP Support",
          "bullets": [
            "Language Server Protocol integration",
            "/lsp show - List installed servers",
            "/lsp test {language} - Verify installation"
          ]
        },
        {
          "header": "Config",
          "bullets": [
            "~/.copilot/config.json - User config",
            ".github/lsp.json - Project LSP config"
          ]
        }
      ]
    },
    {
      "headlines": "Enterprise-Managed Extensions",
      "bullets": [
        "Organizations can auto-install plugins for all developers",
        "Enforce consistent tooling and workflows",
        "Centralized governance for agents, hooks, and MCP configs",
        "Ideal for regulated or large engineering teams"
      ]
    },
    {
      "headlines": "Background Tasks",
      "bullets": [
        "Run long tasks in the cloud without blocking your terminal",
        "Continue working locally while Copilot executes remotely",
        "Perfect for builds, migrations, and large refactors",
        "Supports status checks and result retrieval"
      ]
    },
    {
      "headlines": "Hooks (Extend Copilot's Behavior)",
      "bullets": [
        "Intercept and reshape user prompts before they reach any agent",
        "Add context, enforce rules, or auto-trigger skills",
        "Build safety guards, macros, and custom routing logic",
        "Can optionally run code locally without calling an LLM"
      ]
    },
    {
      "headlines": "Self-Improvement (Experimental Mode)",
      "bullets": [
        "Copilot can scaffold its own extensions (skills, hooks, tools)",
        "Can generate hooks that run without any LLM call",
        "Can modify and improve the extensions it just created",
        "Enables recursive 'Copilot improves Copilot' workflows"
      ]
    },
    {
      "headlines": "Session Wrap-up",
      "bullets": [
        "/chronicle standup - Summary of work done",
        "/chronicle tips - Key learnings",
        "/remote + /keep-alive - Remote session management"
      ]
    }
  ]
}
