{
  "title": "Main Features",
  "slides": [
    {
      "headlines": "Two Operating Modes",
      "sections": [
        {
          "header": "Programmatic Mode",
          "bullets": [
            "copilot -p \"list my open PRs\"",
            "Perfect for scripting and automation"
          ]
        },
        {
          "header": "Interactive Mode",
          "bullets": [
            "Full command access in terminal",
            "Commands start with /"
          ]
        }
      ]
    },
    {
      "headlines": "Essential Commands",
      "bullets": [
        "/update - CLI updates (certain installers)",
        "/models - Switch between available models",
        "/env - Show all extensions",
        "! - to run shell commands"
      ]
    },
    {
      "headlines": "Advanced Features",
      "sections": [
        {
          "header": "Modes",
          "bullets": [
            "Normal mode - Standard operation",
            "Plan mode - Structured planning ([[PLAN]])",
            "Autopilot - Autonomous agents"
          ]
        }
      ]
    },
    {
      "headlines": "Session Management",
      "bullets": [
        "/session - View session history",
        "copilot --resume - Continue previous session",
        "copilot --continue - Resume with context",
        "/share - Writes session to disk "
      ]
    },
    {
      "headlines": "Workspace Control",
      "bullets": [
        "/add-dir - Add directory to context",
        "/context - Manage workspace context",
        "/ide - Visual diff exploration"
      ]
    },
    {
      "headlines": "Agents",
      "bullets": [
        "/tasks - see all running agents",
        "Rubberduck - Code review with GPT-5.4",
        "Explore - Codebase investigation, 'pliz explore ...'",
        "/fleet - Parallel subagent execution for speed",
        "/agent - Create specific agents"
      ]
    },
    {
      "headlines": "Extensibility & Configuration",
      "sections": [
        {
          "header": "Plugins",
          "bullets": [
            "/plugin marketplace list",
            "/plugin marketplace add",
            "/plugin install"
          ]
        },
        {
          "header": "LSP Support",
          "bullets": [
            "Language Server Protocol integration",
            "/lsp show - List installed servers",
            "/lsp test {language} - Verify installation"
          ]
        },
        {
          "header": "Config",
          "bullets": [
            "~/.copilot/config.json - User config",
            ".github/lsp.json - Project LSP config"
          ]
        }
      ]
    },
    {
      "headlines": "Enterprise-Managed Extensions",
      "sections": [
        {
          "header": "Plugins & Marketplaces",
          "bullets": [
            "Create a .github-private repository",
            "Add a settings.json file at .github/copilot/settings.json",
            "extraKnownMarketplaces & enabledPlugins"
          ]
        },
        {
          "header": "Model Context Protocol (MCP)",
          "bullets": [
            "/mcp add - Connect external tools (Sentry, Notion, Azure, etc)",
            "/mcp show - List configured MCP servers",
            "Pre-configured for GitHub, extensible to any service"
          ]
        }
      ]
    },
    {
      "headlines": "Background Tasks & Delegation",
      "bullets": [
        "/tasks - View and manage background tasks",
        "/delegate - Send work to GitHub, create PR automatically",
        "Ctrl+X → b - Move current task to background mid-execution",
        "/remote - Enable remote steering from GitHub web/mobile"
      ]
    },
    {
      "headlines": "Skills & Custom Agents",
      "sections": [
        {
          "header": "Agent Skills",
          "bullets": [
            "/skills list - Browse available skills",
            "/skills info - Get skill details",
            "SKILL.md files in .github/skills for custom workflows"
          ]
        },
        {
          "header": "Custom Instructions & Agents",
          "bullets": [
            "/init - Initialize repo with custom instructions",
            "/instructions - Toggle instruction files",
            "/agent - Select from available specialized agents"
          ]
        }
      ]
    },
    {
      "headlines": "Self-Improvement & Experimentation",
      "bullets": [
        "/experimental - Toggle experimental features on/off",
        "/autopilot - Auto-continue multi-step tasks until complete",
        "Shift+Tab - Cycle between Normal, Plan, and Autopilot modes"
      ]
    },
    {
      "headlines": "Session Wrap-up",
      "bullets": [
        "/chronicle standup - Summary of work done",
        "/chronicle tips - Key learnings",
        "/remote + /keep-alive - Remote session management"
      ]
    }
  ]
}